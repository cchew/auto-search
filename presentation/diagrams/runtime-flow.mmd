%%{init: {'flowchart': {'htmlLabels': true, 'nodeSpacing': 50, 'rankSpacing': 90, 'curve': 'basis'}}}%%
flowchart LR
    user(["<b>WPP user</b><br/><i>Searches by intent,<br/>not exact name</i>"])

    subgraph spa["Vue 3 SPA"]
        direction TB
        searchbar["<b>SearchBar</b><br/><i>Vue 3</i><br/>Debounced input,<br/>min 3 chars"]
        highlight["<b>DataItemHighlight</b><br/><i>Vue 3</i><br/>Scrolls and fades<br/>the matched item"]
    end

    subgraph jvm["Spring Boot (single JVM)"]
        direction TB
        api["<b>SearchController</b><br/><i>Spring REST</i><br/>POST /api/v1/search"]
        embed["<b>EmbeddingService</b><br/><i>ONNX Runtime</i><br/>Fine-tuned MiniLM, INT8"]
        sim["<b>SimilarityService</b><br/><i>Java</i><br/>In-memory cosine<br/>over 350 vectors"]
    end

    user -->|"Types query"| searchbar
    searchbar -->|"JSON over HTTPS"| api
    api -->|"embed(query)"| embed
    api -->|"search(vector, topK=5)"| sim
    api -.->|"Top-K results"| searchbar
    searchbar -->|"Navigate ?highlight=itemId"| highlight

    classDef person fill:#08427b,stroke:#073b6f,color:#fff
    classDef component fill:#85bbf0,stroke:#5d82a8,color:#000
    classDef boundary fill:none,stroke:#666,stroke-dasharray:5 5,color:#333
    class user person
    class searchbar,highlight,api,embed,sim component
    class spa,jvm boundary
